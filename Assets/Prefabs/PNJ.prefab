--- !u!114 &7368432724850235382
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 6860237484474325417}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: eff375ea3badcdd449a1114d49a22bda, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  audioSource: {fileID: 0}
  letterSound: {fileID: 0}
  pitchVariation: 0.2
  soundFrequency: 2
  dialogueText: {fileID: 3184725671160957225}
  dialogueSets:
  - waterLevel: -13
    dialogues:
    - "J'ai vu un bateau au fond du crat\xE8re..."
    - "Je me demande bien comment il est arriv\xE9 l\xE0..."
  - waterLevel: -12
    dialogues:
    - Il me semble bien que le niveau de l'eau monte...
    - "J'ai l'impression que l'eau dans le crat\xE8re \xE9galement."
  - waterLevel: -11
    dialogues:
    - "L'eau est encore mont\xE9e..."
    - "C'est inqui\xE9tant, non?"
    - "Mais peut-\xEAtre que si elle continue de monter..."
    - "Ce b\xE2teau sera enfin accessible..."
  - waterLevel: -10
    dialogues:
    - "L'eau est encore mont\xE9e..."
    - "C'est inqui\xE9tant, non?"
    - "Mais peut-\xEAtre que si elle continue de monter..."
    - "Ce b\xE2teau sera enfin accessible..."
  - waterLevel: -9
    dialogues:
    - "L'eau est encore mont\xE9e..."
    - "C'est inqui\xE9tant, non?"
    - "Mais peut-\xEAtre que si elle continue de monter..."
    - "Ce b\xE2teau sera enfin accessible..."
  - waterLevel: -8
    dialogues:
    - "L'eau est encore mont\xE9e..."
    - "C'est inqui\xE9tant, non?"
    - "Mais peut-\xEAtre que si elle continue de monter..."
    - "Ce b\xE2teau sera enfin accessible..."
  - waterLevel: -7
    dialogues:
    - "L'eau est encore mont\xE9e..."
    - "C'est inqui\xE9tant, non?"
    - "Mais peut-\xEAtre que si elle continue de monter..."
    - "Ce b\xE2teau sera enfin accessible..."
  - waterLevel: -6
    dialogues:
    - "L'eau est encore mont\xE9e..."
    - "C'est inqui\xE9tant, non?"
    - "Mais peut-\xEAtre que si elle continue de monter..."
    - "Ce b\xE2teau sera enfin accessible..."
  - waterLevel: -5
    dialogues:
    - "L'eau est encore mont\xE9e..."
    - "Elle a presque atteint le haut du crat\xE8re!"
    - "Qu'est ce qu'on va devenir si \xE7a continue?"
  - waterLevel: -4
    dialogues:
    - "L'eau est encore mont\xE9e..."
    - "Elle a presque atteint le haut du crat\xE8re!"
    - "Mais ce b\xE2teau m'intrigue..."
  - waterLevel: -3
    dialogues:
    - "L'eau est encore mont\xE9e..."
    - "Elle a presque atteint le haut du crat\xE8re!"
    - "Ce b\xE2teau sera bient\xF4t accessible."
    - Et on pourra enfin naviguer sur ce nouveau lac!
  - waterLevel: -2
    dialogues:
    - "L'eau a atteint le haut du crat\xE8re!"
    - "Je peux enfin aller examiner ce b\xE2teau..."
  - waterLevel: -1
    dialogues:
    - "L'eau a recouvert l'\xEEle dans le lac..."
    - C'est trop tard maintenant...
    - Je voulais tellement m'y rendre, snif!
    - Dommage...
  _waterLevel: 0
  typingSpeed: 0.05
